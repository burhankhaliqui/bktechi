<section class="auth-card">
  <h2>My Profile</h2>
  <div class="auth-form">
    <label>Name</label>
    <input type="text" value="<%= user.name %>" disabled>

    <label>Email</label>
    <input type="email" value="<%= user.email %>" disabled>

    <label>Role</label>
    <input type="text" value="<%= user.role %>" disabled>
  </div>
</section>
