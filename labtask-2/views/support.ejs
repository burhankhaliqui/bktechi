<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Support</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <header class="navbar">
        <div class="nav-container">
            <div class="logo">Apple</div>
            <button class="menu-toggle" id="menuToggle" aria-label="Toggle navigation menu" aria-expanded="false">
                &#9776;
            </button>
            <nav class="nav-right" id="navRight">
                <ul class="nav-menu" id="navMenu">
                    <li><a href="/">Home</a></li>
                    <li><a href="/contact-us">Contact Us</a></li>
                    <li><a href="/support">Support</a></li>
                </ul>
                <div class="icons">Search Cart</div>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero hero-watch dark-text">
            <div class="content">
                <h1>Support</h1>
                <p>Need help? Our support team is ready to assist you.</p>
                <div class="buttons">
                    <a class="btn primary" href="mailto:support@mybookstore.com">Email Support</a>
                    <a class="btn outline" href="/contact-us">Go to Contact Us</a>
                </div>
            </div>
        </section>

        <section class="grid">
            <article class="card light-bg card-trade dark-text">
                <h2>Help Center</h2>
                <p>For order, return, or account help, send us an email anytime.</p>
            </article>

            <article class="card light-bg card-card dark-text">
                <h2>Support Hours</h2>
                <p>Monday to Saturday<br>9:00 AM to 6:00 PM</p>
            </article>
        </section>
    </main>

    <footer class="footer">
        <div class="footer-top">
            <p>We are happy to support you. Thank you for visiting our support page.</p>
        </div>
    </footer>

    <script src="/js/script.js"></script>
    <script src="/js/myscripts.js"></script>
</body>
</html>
