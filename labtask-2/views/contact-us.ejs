<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <header class="navbar">
        <div class="nav-container">
            <div class="logo">Apple</div>
            <button class="menu-toggle" id="menuToggle" aria-label="Toggle navigation menu" aria-expanded="false">
                &#9776;
            </button>
            <nav class="nav-right" id="navRight">
                <ul class="nav-menu" id="navMenu">
                    <li><a href="/">Home</a></li>
                    <li><a href="/contact-us">Contact Us</a></li>
                    <li><a href="/support">Support</a></li>
                </ul>
                <div class="icons">Search Cart</div>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero hero-ipad dark-text">
            <div class="content">
                <h1>Contact Us</h1>
                <p>We are here to help you with your order and support.</p>
                <div class="buttons">
                    <a class="btn primary" href="mailto:support@mybookstore.com">Email Us</a>
                    <a class="btn outline" href="/">Back to Home</a>
                </div>
            </div>
        </section>

        <section class="grid">
            <article class="card light-bg card-trade dark-text">
                <h2>Store Address</h2>
                <p>123 Eden Road, Eden City</p>
            </article>

            <article class="card light-bg card-card dark-text">
                <h2>Phone & Email</h2>
                <p>+1 800 123 4567<br>support@mybookstore.com</p>
            </article>
        </section>
    </main>

    <footer class="footer">
        <div class="footer-top">
            <p>Thank you for visiting our store page. We usually reply within 24 hours.</p>
        </div>
    </footer>

    <script src="/js/script.js"></script>
    <script src="/js/myscripts.js"></script>
</body>
</html>
