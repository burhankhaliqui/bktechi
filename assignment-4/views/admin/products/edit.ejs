<section class="card">
  <div class="card-header">
    <h2>Edit Product</h2>
    <a class="btn" href="/admin/products">Back</a>
  </div>

  <% if (errors && errors.length) { %>
    <div class="alert">Please fill: <%= errors.join(', ') %></div>
  <% } %>

  <form class="form" method="POST" action="/admin/products/edit/<%= product._id %>" enctype="multipart/form-data">
    <div class="field">
      <label>Name</label>
      <input type="text" name="name" value="<%= product.name %>" required>
    </div>
    <div class="field">
      <label>Description</label>
      <textarea name="description" rows="4" required><%= product.description %></textarea>
    </div>
    <div class="field">
      <label>Price</label>
      <input type="number" name="price" step="0.01" min="0" value="<%= product.price %>" required>
    </div>
    <div class="field">
      <label>Category</label>
      <select name="category" required>
        <% const cats = ['iPhone','Mac','iPad','Apple Watch','AirPods','Accessories']; %>
        <option value="">Select</option>
        <% cats.forEach(c => { %>
          <option value="<%= c %>" <%= product.category === c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>
    </div>
    <div class="field">
      <label>Stock</label>
      <input type="number" name="stock" min="0" value="<%= product.stock %>" required>
    </div>
    <div class="field">
      <label>Image (optional)</label>
      <input type="file" name="image" accept="image/*">
    </div>
    <button class="btn primary" type="submit">Save</button>
  </form>
</section>
