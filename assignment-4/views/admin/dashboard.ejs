<section class="card">
  <div class="card-header">
    <h2>All Products</h2>
    <a class="btn" href="/admin/products">Manage Products</a>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Stock</th>
        </tr>
      </thead>
      <tbody>
        <% if (products.length === 0) { %>
          <tr><td colspan="4" class="muted">No products found.</td></tr>
        <% } %>
        <% products.forEach(p => { %>
          <tr>
            <td><%= p.name %></td>
            <td><%= p.category %></td>
            <td>$<%= p.price.toFixed(2) %></td>
            <td><%= p.stock %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
